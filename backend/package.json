{
  "name": "synthetic-newsroom-backend",
  "version": "1.0.0",
  "description": "Synthetic Newsroom POC - Backend",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "pipeline:run": "tsx src/continuous-pipeline.ts",
    "pipeline:trigger": "tsx src/continuous-pipeline.ts",
    "social:test": "tsx src/agents/social_media/test-sandbox.ts",
    "social:test:fast": "tsx src/agents/social_media/test-sandbox.ts --skip-vision"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@prisma/client": "^5.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "fluent-ffmpeg": "^2.1.3",
    "marked": "^12.0.0",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "sharp": "^0.33.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.25",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.10.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
}
