// Prisma schema for Synthetic Newsroom POC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id            String       @id @default(cuid())
  title         String
  pillar        String
  sourceUrl     String
  status        String   @default("PROCESSING") // GREEN, YELLOW, RED, PROCESSING, FAILED, PUBLISHED
  revisionCount Int      @default(0)
  content       String?  @db.Text
  contentHtml   String?  @db.Text
  images        String?  @db.Text  // JSON array of {url, alt, isFeatured}
  editorNotes   String?  @db.Text
  wpPostId      Int?
  wpPostUrl     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  socialPosts   SocialPost[]
}

model SocialPost {
  id            String    @id @default(cuid())
  articleId     String
  article       Article   @relation(fields: [articleId], references: [id])
  pillar        String
  imageCopy     String    // 5-6 word punchy text rendered on image
  caption       String    // Full caption with emojis and hashtags
  postImageUrl  String?   // 1:1 WordPress media URL
  storyImageUrl String?   // 9:16 WordPress media URL
  status        String    @default("PENDING") // PENDING, POSTED, FAILED
  postedAt      DateTime?
  igPostId      String?
  fbPostId      String?
  xPostId       String?
  tiktokPostId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProcessedUrl {
  id        String   @id @default(cuid())
  url       String   @unique @db.Text
  createdAt DateTime @default(now())
}

model PipelineRun {
  id                String        @id @default(cuid())
  status            String        // RUNNING, COMPLETED, FAILED, ABORTED
  articlesProcessed Int           @default(0)
  startedAt         DateTime      @default(now())
  completedAt       DateTime?
  logs              String?       @db.Text  // JSON array of PipelineLogEntry
  videoDigests      VideoDigest[]
}

model VideoDigest {
  id              String      @id @default(cuid())
  runId           String
  pillar          String
  articleIds      String[]
  voiceoverScript String?     @db.Text
  caption         String?     @db.Text
  reelVideoUrl    String?
  storyVideoUrl   String?
  status          String      // PROCESSING | POSTED | FAILED
  igReelId        String?
  igStoryId       String?
  postedAt        DateTime?
  createdAt       DateTime    @default(now())
  errorLog        String?     @db.Text
  pipelineRun     PipelineRun @relation(fields: [runId], references: [id])

  @@index([runId])
  @@index([pillar, createdAt])
}
